DataTable {
    height: 1fr;
}
DataTable:blur > .datatable--cursor {
    color: $text;
}
DataTable:focus > .datatable--cursor {
    background: $accent;
    color: $text;
}
LoadingIndicator {
    display: none;
}
#comments {
    display: none;
    layer: overlay;
    width: 80%;
    height: 80%;
    margin: 2 4;
    background: $surface;
    border: thick $accent;
    padding: 1 2;
}

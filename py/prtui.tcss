DataTable {
    height: 1fr;
}
DataTable:blur > .datatable--cursor {
    color: $text;
}
DataTable:focus > .datatable--cursor {
    background: $accent;
    color: $text;
}
LoadingIndicator {
    display: none;
}
#comments {
    display: none;
    layer: overlay;
    width: 100%;
    height: 100%;
    margin: 3 3 3 3;
    background: $surface;
    border: round $accent;
    padding: 1 2;
}
.review-approval {
    background: darkgreen;
}
.review-changes-requested {
    background: darkorange;
}
.review-dismissed {
    background: grey;
}
.comment-body {
    background: #252535;
}
.comment-thread {
    background: #2d2d3d;
}
.commit {
    background: darkblue;
}
